rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && (request.auth.token.email in ['ahmadmaiyah35@gmail.com', 'emailkedua@gmail.com']); }

    match /appData/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
